# =============================================================
# Variables de entorno para ClassFlow Backend
# Copiar este archivo como .env y completar los valores reales
# =============================================================

# --- ms-auth: JWT ---
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres hex)
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000

# --- ms-notification: Correo SMTP ---
# Usar una "contraseña de aplicación" de Gmail (no la contraseña normal)
# https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_contraseña_de_aplicacion
